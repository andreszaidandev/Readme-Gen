# Required for Gemini API calls in the Vite client.
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# Optional model overrides.
# VITE_GEMINI_MODEL="gemini-2.0-flash"
# VITE_GEMINI_IMAGE_MODEL="gemini-2.0-flash-exp-image-generation"

# Optional client-side free-tier safety limiter.
# Requests are queued and delayed automatically when needed.
# Defaults: 12000ms between calls, 4 calls/minute, 120 calls/day.
# Set VITE_GEMINI_DISABLE_CLIENT_RATE_LIMIT=true to disable.
# VITE_GEMINI_MIN_INTERVAL_MS="12000"
# VITE_GEMINI_MAX_PER_MINUTE="4"
# VITE_GEMINI_MAX_PER_DAY="120"
